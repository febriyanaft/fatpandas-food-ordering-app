<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_banner_gradient"
    android:paddingStart="22dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Judul: Diikat ke Atas (Top) agar tidak terdorong ke bawah -->
    <TextView
        android:id="@+id/tvBannerTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/banner_title"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="0.8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/imgBanner"
        app:layout_constraintHorizontal_bias="0" />

    <!-- Subtitle: Tepat di bawah Judul -->
    <TextView
        android:id="@+id/tvBannerSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/banner_subtitle"
        android:textColor="#E8F5E9"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvBannerTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/imgBanner"
        app:layout_constraintHorizontal_bias="0" />

    <!-- Tombol: Tepat di bawah Subtitle dengan jarak pendek -->
    <TextView
        android:id="@+id/btnBannerOrder"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_banner_button"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Order Now"
        android:textColor="@color/green"
        android:textSize="11sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/tvBannerSubtitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Gambar: Diatur secara vertikal di tengah -->
    <ImageView
        android:id="@+id/imgBanner"
        android:layout_width="95dp"
        android:layout_height="95dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo"
        android:contentDescription="@string/content_desc_banner"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

</androidx.constraintlayout.widget.ConstraintLayout>